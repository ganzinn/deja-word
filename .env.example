# ローカル開発専用。Vercel 本番では以下が自動で供給される:
#   - DATABASE_URL / DATABASE_URL_UNPOOLED: Neon Marketplace Integration が注入
#   - BETTER_AUTH_SECRET: Vercel Dashboard で Production target に手動設定済み (Sensitive)
#   - BETTER_AUTH_URL: 未設定。auth.ts が VERCEL_PROJECT_PRODUCTION_URL から自動生成

DATABASE_URL="postgresql://dejaword:dejaword@localhost:5432/dejaword?schema=public"

# `openssl rand -base64 32` で生成した値をローカル .env.local に投入
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
